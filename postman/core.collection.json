{
  "info": {
    "name": "Alfred - Core API",
    "_postman_id": "alfred-core-v1",
    "description": "Core module: sessions, messages, command executions, memories, working memory, embeddings, transcription. Run in order \u2014 each section builds on the previous (session \u2192 message \u2192 command execution). Note: embedding requests (60-62) call the OpenAI API and require OPENAI_API_KEY to be set; transcription (80) calls the Gemini API and requires GOOGLE_API_KEY to be set.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "00 - Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Status is ok', () => {",
              "    pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
