        }
      }
    },
    {
      "name": "14 - Get Chunk",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns correct chunk', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.id).to.eql(parseInt(pm.environment.get('language_chunk_id')));",
              "    pm.expect(json.status).to.eql('active');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/language/chunks/{{language_chunk_id}}",
          "host": ["{{base_url}}"],
          "path": ["language", "chunks", "{{language_chunk_id}}"]
