{
  "info": {
    "name": "Alfred - Notes API",
    "_postman_id": "alfred-notes-v1",
    "description": "Run in order: Health Check → Create → List → Get → Update → Filter by Tags → Filter by Task → Delete",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "01 - Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Status is ok', () => {",
              "    pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "02 - Create Note",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "pm.test('Response has id and saves it', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.expect(json.title).to.eql('Q4 Planning Notes');",
              "    pm.expect(json.description).to.eql('Key discussion points from the Q4 planning session.');",
              "    pm.expect(json.tags).to.include('work');",
              "    pm.environment.set('note_id', json.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Q4 Planning Notes\",\n  \"description\": \"Key discussion points from the Q4 planning session.\",\n  \"tags\": [\n    \"work\",\n    \"planning\"\n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/notes",
          "host": ["{{base_url}}"],
          "path": ["notes"]
        }
      }
    },
    {
      "name": "03 - List Notes",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is an array', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "    pm.expect(json.length).to.be.at.least(1);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/notes?limit=100",
          "host": ["{{base_url}}"],
          "path": ["notes"],
          "query": [
            {
              "key": "limit",
              "value": "100"
            }
          ]
        }
      }
    },
    {
      "name": "04 - Get Note",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response matches created note', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(String(json.id)).to.eql(String(pm.environment.get('note_id')));",
              "    pm.expect(json.title).to.eql('Q4 Planning Notes');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/notes/{{note_id}}",
          "host": ["{{base_url}}"],
          "path": ["notes", "{{note_id}}"]
        }
      }
    },
    {
      "name": "05 - Update Note (Title & Description)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Title and description were updated', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.title).to.eql('Q4 Planning Notes - Final');",
              "    pm.expect(json.description).to.eql('Updated with action items after the session.');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Q4 Planning Notes - Final\",\n  \"description\": \"Updated with action items after the session.\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/notes/{{note_id}}",
          "host": ["{{base_url}}"],
          "path": ["notes", "{{note_id}}"]
        }
      }
    },
    {
      "name": "06 - List Notes (Filter by Tags)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is an array', () => {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/notes?tags=work&tags=planning&limit=100",
          "host": ["{{base_url}}"],
          "path": ["notes"],
          "query": [
            {
              "key": "tags",
              "value": "work"
            },
            {
              "key": "tags",
              "value": "planning"
            },
            {
              "key": "limit",
              "value": "100"
            }
          ]
        }
      }
    },
    {
      "name": "07 - Get Note Not Found",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 404', () => pm.response.to.have.status(404));",
              "pm.test('Returns not found detail', () => {",
              "    pm.expect(pm.response.json().detail).to.eql('Note not found');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/notes/999999",
          "host": ["{{base_url}}"],
          "path": ["notes", "999999"]
        }
      }
    },
    {
      "name": "08 - Delete Note",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 204', () => pm.response.to.have.status(204));",
              "pm.environment.unset('note_id');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/notes/{{note_id}}",
          "host": ["{{base_url}}"],
          "path": ["notes", "{{note_id}}"]
        }
      }
    }
  ]
}
