        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('All sessions are active (no finished_at)', () => {",
              "    pm.response.json().forEach(s => {",
              "        pm.expect(s.finished_at).to.be.null;",
              "    });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/core/sessions/?active_only=true",
          "host": ["{{base_url}}"],
          "path": ["core", "sessions", ""],
          "query": [{ "key": "active_only", "value": "true" }]
        }
      }
    },
    {
      "name": "04 - Sessions - Get by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Returned session matches ID', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(String(json.id)).to.eql(String(pm.environment.get('core_session_id')));",
              "    pm.expect(json.summary).to.eql('Postman test session');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/core/sessions/{{core_session_id}}",
          "host": ["{{base_url}}"],
          "path": ["core", "sessions", "{{core_session_id}}"]
