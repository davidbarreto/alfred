{
  "info": {
    "name": "Alfred - Commands API",
    "_postman_id": "alfred-commands-v1",
    "description": "Test suite for the Commands API. Flow: /commands/detect → /commands/extract (NL only) → /commands/execute → /commands/respond.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "01 - Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Status is ok', () => {",
              "    pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "02 - Detect: slash command (write)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Slash command detected deterministically', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.operation_type).to.eql('write');",
              "    pm.expect(json.commands).to.be.an('array').with.lengthOf(1);",
              "    const cmd = json.commands[0];",
              "    pm.expect(cmd.type).to.eql('task');",
              "    pm.expect(cmd.command).to.eql('add');",
              "    pm.expect(cmd.source).to.eql('deterministic');",
              "    pm.expect(cmd.confidence).to.eql(1.0);",
              "    pm.expect(cmd.args).to.have.property('title');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"/taskadd Buy groceries\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/detect",
          "host": ["{{base_url}}"],
          "path": ["commands", "detect"]
        }
      }
    },
    {
      "name": "03 - Detect: slash command (read)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Read command detected with operation_type=read', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.operation_type).to.eql('read');",
              "    pm.expect(json.commands[0].command).to.eql('list');",
              "    pm.expect(json.commands[0].source).to.eql('deterministic');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"/tasklist\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/detect",
          "host": ["{{base_url}}"],
          "path": ["commands", "detect"]
        }
      }
    },
    {
      "name": "04 - Detect: multiple slash commands",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Both commands detected', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.commands).to.have.lengthOf(2);",
              "    pm.expect(json.operation_type).to.eql('write');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"/taskadd Buy milk /tasklist\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/detect",
          "host": ["{{base_url}}"],
          "path": ["commands", "detect"]
        }
      }
    },
    {
      "name": "05 - Detect: with Telegram command hint",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Hint path resolves only the hinted command', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.commands).to.have.lengthOf(1);",
              "    const cmd = json.commands[0];",
              "    pm.expect(cmd.type).to.eql('task');",
              "    pm.expect(cmd.args.title).to.eql('buy chocolate');",
              "});",
              "pm.test('Raw text is the original full message', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.raw_text).to.eql('/taskadd buy chocolate /noteadd chocolate is good');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"/taskadd buy chocolate /noteadd chocolate is good\",\n  \"command\": \"/taskadd\",\n  \"args\": \"buy chocolate\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/detect",
          "host": ["{{base_url}}"],
          "path": ["commands", "detect"]
        }
      }
    },
    {
      "name": "06 - Detect: conversational text (no command)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('No commands detected for conversational text', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.operation_type).to.be.null;",
              "    pm.expect(json.commands).to.be.an('array').that.is.empty;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"What's the capital of France?\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/detect",
          "host": ["{{base_url}}"],
          "path": ["commands", "detect"]
        }
      }
    },
    {
      "name": "07 - Extract: args for NL intent (task.add)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Extract returns intent and structured args', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.intent).to.eql('task.add');",
              "    pm.expect(json.args).to.be.an('object');",
              "    pm.expect(json.args).to.have.property('title');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"I need to buy groceries tomorrow\",\n  \"intent\": \"task.add\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/extract",
          "host": ["{{base_url}}"],
          "path": ["commands", "extract"]
        }
      }
    },
    {
      "name": "08 - Extract: args for NL intent (event.add)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Extract returns event args with title', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.intent).to.eql('event.add');",
              "    pm.expect(json.args).to.have.property('title');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Schedule a team meeting next Monday at 10am\",\n  \"intent\": \"event.add\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/extract",
          "host": ["{{base_url}}"],
          "path": ["commands", "extract"]
        }
      }
    },
    {
      "name": "09 - Execute: task add",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Execute response has correct shape', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('ok');",
              "    pm.expect(json.type).to.eql('task');",
              "    pm.expect(json.command).to.eql('add');",
              "    pm.expect(json).to.have.property('result');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message_id\": {{core_message_id}},\n  \"type\": \"task\",\n  \"command\": \"add\",\n  \"args\": {\n    \"title\": \"Buy groceries\",\n    \"priority\": \"HIGH\",\n    \"deadline\": \"2026-06-20\"\n  }\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/execute",
          "host": ["{{base_url}}"],
          "path": ["commands", "execute"]
        }
      }
    },
    {
      "name": "10 - Execute: note add",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Note execute returns ok', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('ok');",
              "    pm.expect(json.type).to.eql('note');",
              "    pm.expect(json.command).to.eql('add');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message_id\": {{core_message_id}},\n  \"type\": \"note\",\n  \"command\": \"add\",\n  \"args\": {\n    \"content\": \"My girlfriend likes oat milk\",\n    \"tags\": \"personal\"\n  }\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/execute",
          "host": ["{{base_url}}"],
          "path": ["commands", "execute"]
        }
      }
    },
    {
      "name": "11 - Execute: task list",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Task list result is array', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('ok');",
              "    pm.expect(json.result).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message_id\": {{core_message_id}},\n  \"type\": \"task\",\n  \"command\": \"list\",\n  \"args\": {\n    \"status\": \"TODO\",\n    \"priority\": \"HIGH\"\n  }\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/execute",
          "host": ["{{base_url}}"],
          "path": ["commands", "execute"]
        }
      }
    },
    {
      "name": "12 - Respond to command results",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response has friendly text', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('response');",
              "    pm.expect(json.response).to.be.a('string');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message_id\": {{core_message_id}}\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/respond",
          "host": ["{{base_url}}"],
          "path": ["commands", "respond"]
        }
      }
    },
    {
      "name": "13 - Respond: no executions (empty response)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is empty string when no executions', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.response).to.eql('');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message_id\": 999999999\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/respond",
          "host": ["{{base_url}}"],
          "path": ["commands", "respond"]
        }
      }
    }
  ]
}
