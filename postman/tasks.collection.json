{
  "info": {
    "name": "Alfred - Tasks API",
    "_postman_id": "alfred-tasks-v1",
    "description": "Run in order: Health Check → Create → List → List (include_recurring) → Get → Update → Complete (Recurring) → List Completions → Complete Again (idempotent) → Filter by Status → Filter by Tags → Delete",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "01 - Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Status is ok', () => {",
              "    pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "02 - Create Task (Recurring Weekly)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "pm.test('Response has id and saves it', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.expect(json.title).to.eql('Buy groceries');",
              "    pm.expect(json.status).to.eql('TODO');",
              "    pm.expect(json.priority).to.eql('MEDIUM');",
              "    pm.expect(json.urgency).to.eql('NORMAL');",
              "    pm.expect(json.recurrence_rule).to.eql('RRULE:FREQ=WEEKLY;BYDAY=MO');",
              "    pm.expect(json.streak).to.be.null;",
              "    pm.expect(json.total_completions).to.be.null;",
              "    pm.environment.set('task_id', json.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Buy groceries\",\n  \"status\": \"TODO\",\n  \"priority\": \"MEDIUM\",\n  \"urgency\": \"NORMAL\",\n  \"tags\": [\n    \"personal\",\n    \"errands\"\n  ],\n  \"recurrence_rule\": \"RRULE:FREQ=WEEKLY;BYDAY=MO\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/organizer/tasks",
          "host": ["{{base_url}}"],
          "path": ["organizer", "tasks"]
        }
      }
    },
    {
      "name": "03 - List Tasks (All)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is an array with at least one task', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "    pm.expect(json.length).to.be.at.least(1);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/organizer/tasks?limit=100",
          "host": ["{{base_url}}"],
          "path": ["organizer", "tasks"],
          "query": [
            { "key": "limit", "value": "100" }
          ]
        }
      }
    },
    {
      "name": "04 - List Tasks (include_recurring with deadline filter)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response includes recurring tasks regardless of deadline', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "    const hasRecurring = json.some(t => t.recurrence_rule !== null);",
              "    pm.expect(hasRecurring).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/organizer/tasks?status=TODO&include_recurring=true&deadline_from=2025-01-01&deadline_to=2025-01-01&limit=100",
          "host": ["{{base_url}}"],
          "path": ["organizer", "tasks"],
          "query": [
            { "key": "status", "value": "TODO" },
            { "key": "include_recurring", "value": "true" },
            { "key": "deadline_from", "value": "2025-01-01" },
            { "key": "deadline_to", "value": "2025-01-01" },
            { "key": "limit", "value": "100" }
          ]
        }
      }
    },
    {
      "name": "05 - Get Task",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response matches created task', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(String(json.id)).to.eql(String(pm.environment.get('task_id')));",
              "    pm.expect(json.title).to.eql('Buy groceries');",
              "    pm.expect(json.status).to.eql('TODO');",
              "    pm.expect(json).to.have.property('streak');",
              "    pm.expect(json).to.have.property('total_completions');",
              "    pm.expect(json).to.have.property('is_done_today');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/organizer/tasks/{{task_id}}",
          "host": ["{{base_url}}"],
          "path": ["organizer", "tasks", "{{task_id}}"]
        }
      }
    },
    {
      "name": "06 - Update Task (Title & Priority)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Title and priority were updated', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.title).to.eql('Buy groceries and household items');",
              "    pm.expect(json.priority).to.eql('HIGH');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Buy groceries and household items\",\n  \"priority\": \"HIGH\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/organizer/tasks/{{task_id}}",
          "host": ["{{base_url}}"],
          "path": ["organizer", "tasks", "{{task_id}}"]
        }
      }
    },
    {
      "name": "07 - Complete Task (Recurring)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Recurring task stays TODO but is_done_today is true', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('TODO');",
              "    pm.expect(json.is_done_today).to.be.true;",
              "    pm.expect(json.total_completions).to.be.at.least(1);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/organizer/tasks/{{task_id}}/complete",
          "host": ["{{base_url}}"],
          "path": ["organizer", "tasks", "{{task_id}}", "complete"]
        }
      }
    },
    {
      "name": "08 - List Task Completions",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns array of completion records', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "    pm.expect(json.length).to.be.at.least(1);",
              "    const c = json[0];",
              "    pm.expect(c).to.have.property('id');",
              "    pm.expect(c).to.have.property('task_id');",
              "    pm.expect(c).to.have.property('occurrence_date');",
              "    pm.expect(c).to.have.property('completed_at');",
              "    pm.expect(String(c.task_id)).to.eql(String(pm.environment.get('task_id')));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/organizer/tasks/{{task_id}}/completions",
          "host": ["{{base_url}}"],
          "path": ["organizer", "tasks", "{{task_id}}", "completions"]
        }
      }
    },
    {
      "name": "09 - Complete Task Again (idempotent)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Still done today, no duplicate completion created', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.is_done_today).to.be.true;",
              "    pm.expect(json.total_completions).to.eql(1);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/organizer/tasks/{{task_id}}/complete",
          "host": ["{{base_url}}"],
          "path": ["organizer", "tasks", "{{task_id}}", "complete"]
        }
      }
    },
    {
      "name": "10 - List Tasks (Filter by Status TODO — recurring still active)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Recurring task still appears as TODO after completion', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "    const task = json.find(t => String(t.id) === String(pm.environment.get('task_id')));",
              "    pm.expect(task).to.not.be.undefined;",
              "    pm.expect(task.status).to.eql('TODO');",
              "    pm.expect(task.is_done_today).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/organizer/tasks?status=TODO&limit=100",
          "host": ["{{base_url}}"],
          "path": ["organizer", "tasks"],
          "query": [
            { "key": "status", "value": "TODO" },
            { "key": "limit", "value": "100" }
          ]
        }
      }
    },
    {
      "name": "11 - List Tasks (Filter by Tags)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is an array', () => {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/organizer/tasks?tags=personal&tags=errands&limit=100",
          "host": ["{{base_url}}"],
          "path": ["organizer", "tasks"],
          "query": [
            { "key": "tags", "value": "personal" },
            { "key": "tags", "value": "errands" },
            { "key": "limit", "value": "100" }
          ]
        }
      }
    },
    {
      "name": "12 - Delete Task",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 204', () => pm.response.to.have.status(204));",
              "pm.environment.unset('task_id');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/organizer/tasks/{{task_id}}",
          "host": ["{{base_url}}"],
          "path": ["organizer", "tasks", "{{task_id}}"]
        }
      }
    }
  ]
}
