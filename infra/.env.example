# Environment selection: local / production
ENV=<local|production>
LOG_LEVEL=INFO|DEBUG

# n8n
N8N_PORT=5678
N8N_HOST=<ROOT_HOSTNAME>
N8N_PROTOCOL=https
WEBHOOK_URL=https://<ROOT_HOSTNAME>
N8N_EDITOR_BASE_URL=https://<ROOT_HOSTNAME>
NODE_ENV=production
TIMEZONE=Europe/Lisbon
N8N_ENCRYPTION_KEY= # Generate with 'openssl rand -hex 32'
N8N_DATA_DIR= # Directory to store data from N8N container 
N8N_OWNER_EMAIL=david.brto@gmail.com
N8N_OWNER_PASSWORD=<Password with upper/lower case letthers + numbers>
N8N_OWNER_FIRST_NAME=<NAME>
N8N_OWNER_LAST_NAME=<LAST NAME>

# PostgreSQL / pgvector
DB_HOST=db
DB_PORT=5432
DB_NAME=alfred_db
DB_USER=alfred_app
DB_PASSWORD=alfred_app_password
DB_ADMIN_USER=alfred_admin
DB_ADMIN_PASSWORD=alfred_admin_password
DB_DATA_DIR= # Directory to store data from DB container
N8N_DB_NAME=n8n_db
N8N_DB_USER=alfred_n8n
N8N_DB_PASSWORD=alfred_n8n_password
N8N_DB_HOST=${DB_HOST}
N8N_DB_PORT=${DB_PORT}

# FastAPI backend
HF_CACHE_DIR= # Directory to persist HuggingFace model cache (e.g. /srv/data/alfred/hf_cache)
AUDIO_DATA_DIR= # Directory to persist shadowing recordings + pronunciation TTS cache (e.g. /srv/data/alfred/audio)
AUDIO_STORAGE_DIR=/data/audio
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
BACKEND_RELOAD=false
ALFRED_API_TOKEN=TOKEN
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
DATABASE_ADMIN_URL=postgresql+asyncpg://${DB_ADMIN_USER}:${DB_ADMIN_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
VECTOR_EXTENSION=pgvector
NOTION_API_KEY=api_key
NOTION_BASE_URL=url
NOTION_API_VERSION=version
NOTION_TASKS_DATABASE_ID=task_db_id
NOTION_NOTES_DATABASE_ID=note_db_id
GOOGLE_CLIENT_ID=client_id
GOOGLE_CLIENT_SECRET=client_secret
GOOGLE_CALENDAR_OAUTH_REDIRECT_URI=https://<ROOT_HOSTNAME>/integration/google-calendar/oauth/callback
GOOGLE_CONTACTS_OAUTH_REDIRECT_URI=https://<ROOT_HOSTNAME>/integration/google-contacts/oauth/callback
GOOGLE_CALENDAR_ID=primary
GOOGLE_API_KEY=api_key # aistudio.google.com

# n8n credential template vars (n8n-only; not used by FastAPI)
TELEGRAM_BOT_TOKEN=bot_token         # From @BotFather on Telegram
TELEGRAM_CHAT_ID=chat_id             # Message the bot once, then GET https://api.telegram.org/bot<token>/getUpdates to find it
EMBEDDING_MODEL=all-MiniLM-L6-v2
LLM_CHAT_MODEL=gemini-2.0-flash
LLM_CHAT_TEMPERATURE=0.35
LLM_EXTRACTION_MODEL=gemini-2.0-flash-lite
LLM_PRONUNCIATION_MODEL=gemini-2.5-flash
LLM_TRANSCRIPTION_MODEL=gemini-2.5-flash
INTENT_THRESHOLD=0.75

# Web portal
WEB_PORT=8080
CORS_ORIGINS=https://<WEB_HOSTNAME>     # Origin of the web portal (used by backend for CORS)
PUBLIC_BACKEND_URL=https://<API_HOSTNAME> # Browser-accessible backend URL (for chat SSE)
WEB_PASSWORD=<strong-password>            # Portal login password
SESSION_SECRET_KEY=<random-64-char-hex>   # Cookie signing key — generate: openssl rand -hex 32