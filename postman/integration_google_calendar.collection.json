{
  "info": {
    "name": "Alfred - Google Calendar OAuth",
    "_postman_id": "alfred-google-calendar-oauth-v1",
    "description": "OAuth flow and sync for Google Calendar. Run 01 to get the authorization URL, open it in a browser, authorize, and Google will call the callback automatically. Run 04/05 to sync events from Google Calendar into Alfred for a given date range (defaults to today through 3 months ahead).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "01 - Status",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response has authorized field', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('authorized');",
              "    console.log('Google Calendar authorized:', json.authorized);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/google-calendar/status",
          "host": ["{{base_url}}"],
          "path": ["integration", "google-calendar", "status"]
        }
      }
    },
    {
      "name": "02 - Get Authorization URL",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response contains url', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('url');",
              "    pm.expect(json.url).to.include('accounts.google.com');",
              "    console.log('Open this URL in a browser to authorize:', json.url);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/google-calendar/oauth/url",
          "host": ["{{base_url}}"],
          "path": ["integration", "google-calendar", "oauth", "url"]
        }
      }
    },
    {
      "name": "03 - OAuth Callback (manual test)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Authorization successful', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/google-calendar/oauth/callback?code=PASTE_CODE_HERE",
          "host": ["{{base_url}}"],
          "path": ["integration", "google-calendar", "oauth", "callback"],
          "query": [
            { "key": "code", "value": "PASTE_CODE_HERE" }
          ]
        }
      }
    },
    {
      "name": "04 - Sync Calendar (default range)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response has sync result fields', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('created');",
              "    pm.expect(json).to.have.property('updated');",
              "    pm.expect(json).to.have.property('start');",
              "    pm.expect(json).to.have.property('end');",
              "    console.log('Synced calendar:', json);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/google-calendar/sync",
          "host": ["{{base_url}}"],
          "path": ["integration", "google-calendar", "sync"]
        }
      }
    },
    {
      "name": "05 - Sync Calendar (explicit range)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response echoes requested range', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.start).to.eql('2026-08-01');",
              "    pm.expect(json.end).to.eql('2026-08-31');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/google-calendar/sync?start=2026-08-01&end=2026-08-31",
          "host": ["{{base_url}}"],
          "path": ["integration", "google-calendar", "sync"],
          "query": [
            { "key": "start", "value": "2026-08-01" },
            { "key": "end", "value": "2026-08-31" }
          ]
        }
      }
    }
  ]
}
