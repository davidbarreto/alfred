{
  "info": {
    "name": "Alfred - Google Contacts OAuth",
    "_postman_id": "alfred-google-contacts-oauth-v1",
    "description": "OAuth flow and sync for Google Contacts. Run 01 to check status, 02 to get the authorization URL (open in a browser), then 04 to sync contacts.\n\nNOTE: The OAuth scope is now 'contacts' (full access) instead of 'contacts.readonly'. If you previously authorized with readonly scope, you must re-authorize by hitting 02 again and consenting to the new scope.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "01 - Status",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response has authorized field', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('authorized');",
              "    console.log('Google Contacts authorized:', json.authorized);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/google-contacts/status",
          "host": ["{{base_url}}"],
          "path": ["integration", "google-contacts", "status"]
        }
      }
    },
    {
      "name": "02 - Get Authorization URL",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response contains url', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('url');",
              "    pm.expect(json.url).to.include('accounts.google.com');",
              "    console.log('Open this URL in a browser to authorize:', json.url);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/google-contacts/oauth/url",
          "host": ["{{base_url}}"],
          "path": ["integration", "google-contacts", "oauth", "url"]
        }
      }
    },
    {
      "name": "03 - OAuth Callback (manual test)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Authorization successful', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/google-contacts/oauth/callback?code=PASTE_CODE_HERE",
          "host": ["{{base_url}}"],
          "path": ["integration", "google-contacts", "oauth", "callback"],
          "query": [
            { "key": "code", "value": "PASTE_CODE_HERE" }
          ]
        }
      }
    },
    {
      "name": "04 - Sync Contacts",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response has synced count', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('synced');",
              "    pm.expect(json.synced).to.be.a('number');",
              "    console.log('Synced contacts:', json.synced);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/google-contacts/sync",
          "host": ["{{base_url}}"],
          "path": ["integration", "google-contacts", "sync"]
        }
      }
    }
  ]
}
