{
  "info": {
    "name": "Alfred - Integration LLM Calls API",
    "_postman_id": "alfred-integration-llm-calls-v1",
    "description": "Read-only. Run in order: Health Check → List → List (filtered by model) → List (filtered by feature) → List (text search) → List (date range) → Get by ID → Get 404",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "01 - Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Status is ok', () => {",
              "    pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "02 - List LLM Calls",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is an array', () => {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});",
              "pm.test('Items have expected shape', () => {",
              "    const json = pm.response.json();",
              "    if (json.length === 0) return;",
              "    const item = json[0];",
              "    ['id', 'model', 'feature', 'prompt', 'response', 'created_at'].forEach(field => {",
              "        pm.expect(item).to.have.property(field);",
              "    });",
              "    pm.environment.set('llm_call_id', item.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/llm-calls/?skip=0&limit=50",
          "host": ["{{base_url}}"],
          "path": ["integration", "llm-calls", ""],
          "query": [
            { "key": "skip", "value": "0" },
            { "key": "limit", "value": "50" }
          ]
        }
      }
    },
    {
      "name": "03 - List LLM Calls - No Auth",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('No auth returns 403', () => pm.response.to.have.status(403));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/llm-calls/",
          "host": ["{{base_url}}"],
          "path": ["integration", "llm-calls", ""]
        }
      }
    },
    {
      "name": "04 - List LLM Calls - Wrong Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Wrong token returns 401', () => pm.response.to.have.status(401));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "invalid-token", "type": "string" }]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/llm-calls/",
          "host": ["{{base_url}}"],
          "path": ["integration", "llm-calls", ""]
        }
      }
    },
    {
      "name": "05 - List LLM Calls - Filter by Provider",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('All items match provider filter', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "    json.forEach(item => {",
              "        pm.expect(item.provider).to.eql('anthropic');",
              "    });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/llm-calls/?provider=anthropic",
          "host": ["{{base_url}}"],
          "path": ["integration", "llm-calls", ""],
          "query": [
            { "key": "provider", "value": "anthropic" }
          ]
        }
      }
    },
    {
      "name": "07 - List LLM Calls - Filter by Model",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('All items match model filter', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "    json.forEach(item => {",
              "        pm.expect(item.model).to.eql('claude-sonnet-4-6');",
              "    });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/llm-calls/?model=claude-sonnet-4-6",
          "host": ["{{base_url}}"],
          "path": ["integration", "llm-calls", ""],
          "query": [
            { "key": "model", "value": "claude-sonnet-4-6" }
          ]
        }
      }
    },
    {
      "name": "08 - List LLM Calls - Filter by Feature",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('All items match feature filter', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "    json.forEach(item => {",
              "        pm.expect(item.feature).to.eql('chat');",
              "    });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/llm-calls/?feature=chat",
          "host": ["{{base_url}}"],
          "path": ["integration", "llm-calls", ""],
          "query": [
            { "key": "feature", "value": "chat" }
          ]
        }
      }
    },
    {
      "name": "09 - List LLM Calls - Text Search (q)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is an array', () => {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/llm-calls/?q=hello",
          "host": ["{{base_url}}"],
          "path": ["integration", "llm-calls", ""],
          "query": [
            { "key": "q", "value": "hello" }
          ]
        }
      }
    },
    {
      "name": "10 - List LLM Calls - Date Range (after/before)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is an array', () => {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});",
              "pm.test('Items fall within date range', () => {",
              "    const json = pm.response.json();",
              "    if (json.length === 0) return;",
              "    const after = new Date('2020-01-01T00:00:00Z');",
              "    const before = new Date('2099-12-31T23:59:59Z');",
              "    json.forEach(item => {",
              "        const ts = new Date(item.created_at);",
              "        pm.expect(ts >= after && ts <= before).to.be.true;",
              "    });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/llm-calls/?after=2020-01-01T00:00:00Z&before=2099-12-31T23:59:59Z",
          "host": ["{{base_url}}"],
          "path": ["integration", "llm-calls", ""],
          "query": [
            { "key": "after", "value": "2020-01-01T00:00:00Z" },
            { "key": "before", "value": "2099-12-31T23:59:59Z" }
          ]
        }
      }
    },
    {
      "name": "11 - Get LLM Call by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const callId = pm.environment.get('llm_call_id');",
              "if (!callId) {",
              "    pm.test('Skipped — no llm_call_id (empty DB)', () => true);",
              "    return;",
              "}",
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Returned call matches requested ID', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(String(json.id)).to.eql(String(callId));",
              "    ['model', 'feature', 'prompt', 'response', 'created_at'].forEach(field => {",
              "        pm.expect(json).to.have.property(field);",
              "    });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/llm-calls/{{llm_call_id}}",
          "host": ["{{base_url}}"],
          "path": ["integration", "llm-calls", "{{llm_call_id}}"]
        }
      }
    },
    {
      "name": "12 - Get LLM Call - Not Found",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Non-existent call returns 404', () => pm.response.to.have.status(404));",
              "pm.test('Error detail is present', () => {",
              "    pm.expect(pm.response.json()).to.have.property('detail');",
              "});",
              "pm.environment.unset('llm_call_id');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integration/llm-calls/999999999",
          "host": ["{{base_url}}"],
          "path": ["integration", "llm-calls", "999999999"]
        }
      }
    }
  ]
}
