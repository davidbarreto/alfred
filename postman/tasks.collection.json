{
  "info": {
    "name": "Alfred - Tasks API",
    "_postman_id": "alfred-tasks-v1",
    "description": "Run in order: Health Check \u2192 Create \u2192 List \u2192 Get \u2192 Update Title \u2192 Mark Done \u2192 Filter by Status \u2192 Filter by Tags \u2192 Delete",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "01 - Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Status is ok', () => {",
              "    pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "02 - Create Task",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "pm.test('Response has id and saves it', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.expect(json.title).to.eql('Buy groceries');",
              "    pm.expect(json.status).to.eql('TODO');",
              "    pm.expect(json.priority).to.eql('MEDIUM');",
              "    pm.expect(json.urgency).to.eql('NORMAL');",
              "    pm.expect(json.recurrence_rule).to.eql('RRULE:FREQ=WEEKLY;BYDAY=MO');",
              "    pm.environment.set('task_id', json.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Buy groceries\",\n  \"status\": \"TODO\",\n  \"priority\": \"MEDIUM\",\n  \"urgency\": \"NORMAL\",\n  \"tags\": [\n    \"personal\",\n    \"errands\"\n  ],\n  \"recurrence_rule\": \"RRULE:FREQ=WEEKLY;BYDAY=MO\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/tasks",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "tasks"
          ]
        }
      }
    },
    {
      "name": "03 - List Tasks",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is an array', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "    pm.expect(json.length).to.be.at.least(1);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/tasks?limit=100",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "tasks"
          ],
          "query": [
            {
              "key": "limit",
              "value": "100"
            }
          ]
        }
      }
    },
    {
      "name": "04 - Get Task",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response matches created task', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(String(json.id)).to.eql(String(pm.environment.get('task_id')));",
              "    pm.expect(json.title).to.eql('Buy groceries');",
              "    pm.expect(json.status).to.eql('TODO');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/tasks/{{task_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "tasks",
            "{{task_id}}"
          ]
        }
      }
    },
    {
      "name": "05 - Update Task (Title & Priority)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Title and priority were updated', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.title).to.eql('Buy groceries and household items');",
              "    pm.expect(json.priority).to.eql('HIGH');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Buy groceries and household items\",\n  \"priority\": \"HIGH\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/tasks/{{task_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "tasks",
            "{{task_id}}"
          ]
        }
      }
    },
    {
      "name": "06 - Update Task (Mark as DONE)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Status is now DONE', () => {",
              "    pm.expect(pm.response.json().status).to.eql('DONE');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"DONE\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/tasks/{{task_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "tasks",
            "{{task_id}}"
          ]
        }
      }
    },
    {
      "name": "07 - List Tasks (Filter by Status DONE)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('All returned tasks have status DONE', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "    json.forEach(task => pm.expect(task.status).to.eql('DONE'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/tasks?status=DONE&limit=100",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "tasks"
          ],
          "query": [
            {
              "key": "status",
              "value": "DONE"
            },
            {
              "key": "limit",
              "value": "100"
            }
          ]
        }
      }
    },
    {
      "name": "08 - List Tasks (Filter by Tags)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is an array', () => {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/tasks?tags=personal&tags=errands&limit=100",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "tasks"
          ],
          "query": [
            {
              "key": "tags",
              "value": "personal"
            },
            {
              "key": "tags",
              "value": "errands"
            },
            {
              "key": "limit",
              "value": "100"
            }
          ]
        }
      }
    },
    {
      "name": "09 - Delete Task",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 204', () => pm.response.to.have.status(204));",
              "pm.environment.unset('task_id');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/tasks/{{task_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "tasks",
            "{{task_id}}"
          ]
        }
      }
    }
  ]
}