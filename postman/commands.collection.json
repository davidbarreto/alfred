{
  "info": {
    "name": "Alfred - Commands API",
    "_postman_id": "alfred-commands-v1",
    "description": "Test suite for the Commands API — resolves natural language text into structured commands.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "01 - Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Status is ok', () => {",
              "    pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "02 - Resolve Task Command",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response has status and commands', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('status');",
              "    pm.expect(json).to.have.property('commands');",
              "    pm.expect(json).to.have.property('raw_text');",
              "    pm.expect(json.commands).to.be.an('array');",
              "});",
              "pm.test('Command was parsed', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('ok');",
              "    pm.expect(json.commands.length).to.be.at.least(1);",
              "    const cmd = json.commands[0];",
              "    pm.expect(cmd).to.have.property('type');",
              "    pm.expect(cmd).to.have.property('command');",
              "    pm.expect(cmd).to.have.property('confidence');",
              "    pm.expect(cmd).to.have.property('args');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"/task add Buy groceries priority:high\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/resolve",
          "host": ["{{base_url}}"],
          "path": ["commands", "resolve"]
        }
      }
    },
    {
      "name": "03 - Resolve Note Command",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response has status and commands', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('status');",
              "    pm.expect(json).to.have.property('commands');",
              "    pm.expect(json).to.have.property('raw_text');",
              "    pm.expect(json.commands).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"/note add Meeting notes from standup: discussed roadmap and Q3 priorities\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/resolve",
          "host": ["{{base_url}}"],
          "path": ["commands", "resolve"]
        }
      }
    },
    {
      "name": "04 - Resolve With Command Hint (Single Command)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Exactly one command resolved from hint', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('ok');",
              "    pm.expect(json.commands).to.have.lengthOf(1);",
              "    const cmd = json.commands[0];",
              "    pm.expect(cmd.type).to.eql('task');",
              "    pm.expect(cmd.command).to.eql('add');",
              "    pm.expect(cmd.args.task).to.eql('buy chocolate');",
              "});",
              "pm.test('Raw text is original full message', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.raw_text).to.eql('/taskadd buy chocolate /noteadd chocolate is good');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"/taskadd buy chocolate /noteadd chocolate is good\",\n  \"command\": \"/taskadd\",\n  \"args\": \"buy chocolate\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/resolve",
          "host": ["{{base_url}}"],
          "path": ["commands", "resolve"]
        }
      }
    },
    {
      "name": "05 - Resolve With Command Hint (Note, With Flags)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Note command resolved with tag', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('ok');",
              "    pm.expect(json.commands).to.have.lengthOf(1);",
              "    const cmd = json.commands[0];",
              "    pm.expect(cmd.type).to.eql('note');",
              "    pm.expect(cmd.command).to.eql('add');",
              "    pm.expect(cmd.args).to.have.property('tags');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"/noteadd chocolate is good -t food\",\n  \"command\": \"/noteadd\",\n  \"args\": \"chocolate is good -t food\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/resolve",
          "host": ["{{base_url}}"],
          "path": ["commands", "resolve"]
        }
      }
    },
    {
      "name": "06 - Resolve Unparseable Text",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Status is not_parsed for plain text', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('status');",
              "    pm.expect(json).to.have.property('raw_text');",
              "    pm.expect(json.raw_text).to.eql('hello world');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"hello world\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/resolve",
          "host": ["{{base_url}}"],
          "path": ["commands", "resolve"]
        }
      }
    },
    {
      "name": "07 - Execute Task Add",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Execute response has correct shape', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('ok');",
              "    pm.expect(json.type).to.eql('task');",
              "    pm.expect(json.command).to.eql('add');",
              "    pm.expect(json).to.have.property('result');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"task\",\n  \"command\": \"add\",\n  \"args\": {\n    \"task\": \"Buy groceries\",\n    \"priority\": \"HIGH\",\n    \"deadline\": \"2026-06-20\"\n  }\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/execute",
          "host": ["{{base_url}}"],
          "path": ["commands", "execute"]
        }
      }
    },
    {
      "name": "08 - Execute Note Add",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Note execute returns ok', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('ok');",
              "    pm.expect(json.type).to.eql('note');",
              "    pm.expect(json.command).to.eql('add');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"note\",\n  \"command\": \"add\",\n  \"args\": {\n    \"content\": \"My girlfriend likes oat milk\",\n    \"tags\": \"personal\"\n  }\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/execute",
          "host": ["{{base_url}}"],
          "path": ["commands", "execute"]
        }
      }
    },
    {
      "name": "09 - Execute Task List",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Task list result is array', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('ok');",
              "    pm.expect(json.result).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"task\",\n  \"command\": \"list\",\n  \"args\": {\n    \"status\": \"TODO\",\n    \"priority\": \"HIGH\"\n  }\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/execute",
          "host": ["{{base_url}}"],
          "path": ["commands", "execute"]
        }
      }
    },
    {
      "name": "10 - Respond to Command Results",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response has friendly text', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('response');",
              "    pm.expect(json.response).to.be.a('string');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message_id\": {{core_message_id}}\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/respond",
          "host": ["{{base_url}}"],
          "path": ["commands", "respond"]
        }
      }
    },
    {
      "name": "11 - Respond - No executions (empty response)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is empty string when no executions', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.response).to.eql('');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message_id\": 999999999\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/commands/respond",
          "host": ["{{base_url}}"],
          "path": ["commands", "respond"]
        }
      }
    }
  ]
}