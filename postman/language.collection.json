{
  "info": {
    "name": "Alfred - Language API",
    "_postman_id": "alfred-language-v1",
    "description": "Run in order: Health Check → Create Track → Create Grammar Scope → Bulk Create Scopes → Create Chunk → Approve Chunk → Get Daily Batch → Record SRS Review → Record Shadowing → Get Daily Progress → List Sessions → Get Pronunciation (mp3/ogg) → Cleanup",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "01 - Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Status is ok', () => {",
              "    pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "02 - Create Track",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "pm.test('Response has id and saves it', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.expect(json.code).to.eql('pt');",
              "    pm.expect(json.name).to.eql('Portuguese');",
              "    pm.expect(json.level).to.eql('B1');",
              "    pm.expect(json.daily_quota).to.eql(10);",
              "    pm.expect(json.review_mode).to.eql('balanced');",
              "    pm.expect(json.active).to.be.true;",
              "    pm.environment.set('language_track_id', json.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"pt\",\n  \"name\": \"Portuguese\",\n  \"level\": \"B1\",\n  \"daily_quota\": 10,\n  \"review_mode\": \"balanced\",\n  \"active\": true\n}",
          "options": {"raw": {"language": "json"}}
        },
        "url": {
          "raw": "{{base_url}}/language/tracks",
          "host": ["{{base_url}}"],
          "path": ["language", "tracks"]
        }
      }
    },
    {
      "name": "03 - List Tracks",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is an array with at least one track', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "    pm.expect(json.length).to.be.at.least(1);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/language/tracks?active_only=true",
          "host": ["{{base_url}}"],
          "path": ["language", "tracks"],
          "query": [{"key": "active_only", "value": "true"}]
        }
      }
    },
    {
      "name": "04 - Get Track",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns correct track', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.id).to.eql(parseInt(pm.environment.get('language_track_id')));",
              "    pm.expect(json.code).to.eql('pt');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/language/tracks/{{language_track_id}}",
          "host": ["{{base_url}}"],
          "path": ["language", "tracks", "{{language_track_id}}"]
        }
      }
    },
    {
      "name": "05 - Update Track",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('daily_quota updated', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.daily_quota).to.eql(15);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"daily_quota\": 15\n}",
          "options": {"raw": {"language": "json"}}
        },
        "url": {
          "raw": "{{base_url}}/language/tracks/{{language_track_id}}",
          "host": ["{{base_url}}"],
          "path": ["language", "tracks", "{{language_track_id}}"]
        }
      }
    },
    {
      "name": "06 - Create Grammar Scope",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "pm.test('Response has id and saves it', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.expect(json.category).to.eql('verb_tense');",
              "    pm.expect(json.value).to.eql('presente indicativo');",
              "    pm.expect(json.status).to.eql('deferred');",
              "    pm.environment.set('language_scope_id', json.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"track_id\": {{language_track_id}},\n  \"category\": \"verb_tense\",\n  \"value\": \"presente indicativo\",\n  \"priority\": 1,\n  \"status\": \"deferred\"\n}",
          "options": {"raw": {"language": "json"}}
        },
        "url": {
          "raw": "{{base_url}}/language/grammar-scope",
          "host": ["{{base_url}}"],
          "path": ["language", "grammar-scope"]
        }
      }
    },
    {
      "name": "07 - Bulk Create Grammar Scopes",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "pm.test('Returns array of scopes', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "    pm.expect(json.length).to.eql(2);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "[\n  {\n    \"track_id\": {{language_track_id}},\n    \"category\": \"verb_tense\",\n    \"value\": \"preterito perfeito\",\n    \"priority\": 2,\n    \"status\": \"deferred\"\n  },\n  {\n    \"track_id\": {{language_track_id}},\n    \"category\": \"verb_tense\",\n    \"value\": \"futuro simples\",\n    \"priority\": 3,\n    \"status\": \"deferred\"\n  }\n]",
          "options": {"raw": {"language": "json"}}
        },
        "url": {
          "raw": "{{base_url}}/language/grammar-scope/bulk",
          "host": ["{{base_url}}"],
          "path": ["language", "grammar-scope", "bulk"]
        }
      }
    },
    {
      "name": "08 - List Grammar Scopes",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns scopes for track', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "    pm.expect(json.length).to.be.at.least(1);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/language/grammar-scope?track_id={{language_track_id}}",
          "host": ["{{base_url}}"],
          "path": ["language", "grammar-scope"],
          "query": [{"key": "track_id", "value": "{{language_track_id}}"}]
        }
      }
    },
    {
      "name": "09 - Activate Grammar Scope",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Status set to active', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('active');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"active\"\n}",
          "options": {"raw": {"language": "json"}}
        },
        "url": {
          "raw": "{{base_url}}/language/grammar-scope/{{language_scope_id}}",
          "host": ["{{base_url}}"],
          "path": ["language", "grammar-scope", "{{language_scope_id}}"]
        }
      }
    },
    {
      "name": "10 - Create Chunk (pending triage)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "pm.test('Response has id and saves it', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.expect(json.text).to.eql('falar com alguém');",
              "    pm.expect(json.chunk_type).to.eql('collocation');",
              "    pm.expect(json.status).to.eql('pending_triage');",
              "    pm.expect(json.state).to.eql('new');",
              "    pm.expect(json.is_leech).to.be.false;",
              "    pm.environment.set('language_chunk_id', json.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"track_id\": {{language_track_id}},\n  \"grammar_scope_id\": {{language_scope_id}},\n  \"chunk_type\": \"collocation\",\n  \"text\": \"falar com alguém\",\n  \"translation\": \"to talk to someone\",\n  \"example_sentence\": \"Preciso de falar com alguém sobre isto.\",\n  \"example_translation\": \"I need to talk to someone about this.\",\n  \"cefr_level\": \"B1\",\n  \"frequency_rank\": 42,\n  \"frequency_source\": \"pareto_list\"\n}",
          "options": {"raw": {"language": "json"}}
        },
        "url": {
          "raw": "{{base_url}}/language/chunks",
          "host": ["{{base_url}}"],
          "path": ["language", "chunks"]
        }
      }
    },
    {
      "name": "11 - List Chunks (pending triage)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns pending triage chunks', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "    pm.expect(json.length).to.be.at.least(1);",
              "    pm.expect(json[0].status).to.eql('pending_triage');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/language/chunks?track_id={{language_track_id}}&status=pending_triage",
          "host": ["{{base_url}}"],
          "path": ["language", "chunks"],
          "query": [
            {"key": "track_id", "value": "{{language_track_id}}"},
            {"key": "status", "value": "pending_triage"}
          ]
        }
      }
    },
    {
      "name": "12 - Approve Chunk",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Chunk status is active', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('active');",
