                  "    pm.expect(json.status).to.eql('pending');",
                  "    pm.expect(json.store).to.eql('Pingo Doce');",
                  "    pm.environment.set('shopping_item_id', json.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Beans\",\n  \"category_id\": {{shopping_grocery_category_id}},\n  \"priority\": \"need\",\n  \"quantity\": 2,\n  \"unit\": \"cans\",\n  \"store\": \"Pingo Doce\",\n  \"notes\": \"Red kidney beans\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/organizer/shopping/",
              "host": ["{{base_url}}"],
              "path": ["organizer", "shopping", ""]
            }
          }
        },
