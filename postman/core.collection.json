{
  "info": {
    "name": "Alfred - Core API",
    "_postman_id": "alfred-core-v1",
    "description": "Core module: sessions, messages, command executions, memories, working memory, embeddings. Run in order — each section builds on the previous (session → message → command execution). Note: embedding requests (60-62) call the OpenAI API and require OPENAI_API_KEY to be set.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "00 - Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Status is ok', () => {",
              "    pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },

    {
      "name": "01 - Sessions - Create",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "pm.test('Response has expected shape', () => {",
              "    const json = pm.response.json();",
              "    ['id', 'created_at'].forEach(f => pm.expect(json).to.have.property(f));",
              "    pm.expect(json.finished_at).to.be.null;",
              "});",
              "pm.environment.set('core_session_id', pm.response.json().id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"summary\": \"Postman test session\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/core/sessions/",
          "host": ["{{base_url}}"],
          "path": ["core", "sessions", ""]
        }
      }
    },
    {
      "name": "02 - Sessions - List",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is an array', () => {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/core/sessions/",
          "host": ["{{base_url}}"],
          "path": ["core", "sessions", ""]
        }
      }
    },
    {
      "name": "03 - Sessions - List Active Only",
